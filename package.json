{
  "name": "doctormx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "lint": "next lint",
    "lint:strict": "npx eslint . --max-warnings=10",
    "lint:fix": "npx eslint . --fix",
    "lint:i18n": "npx eslint src --ext .ts,.tsx --rule 'custom/no-hardcoded-spanish: error' --max-warnings=0",
    "type-check": "tsc --noEmit --strict",
    "typecheck": "tsc --noEmit",
    "quality:report": "node scripts/quality/generate-report.js",
    "quality:check": "npm run lint && npm run type-check && npm run test",
    "test:changed": "vitest run --changed",
    "quality-check": "npm run lint && npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "next start",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "sentry:release": "sentry-cli releases new $npm_package_version",
    "sentry:upload": "sentry-cli releases files $npm_package_version upload-sourcemaps .next",
    "sentry:finalize": "sentry-cli releases finalize $npm_package_version",
    "sentry:deploy": "npm run sentry:release && npm run sentry:upload && npm run sentry:finalize",
    "test:load": "k6 run",
    "test:load:concurrent": "k6 run tests/load/concurrent-users.js",
    "test:load:api": "k6 run tests/load/api-load.js",
    "test:load:booking": "k6 run tests/load/booking-surge.js",
    "test:load:video": "k6 run tests/load/video-consultation.js",
    "test:load:all": "npm run test:load:concurrent && npm run test:load:api && npm run test:load:booking && npm run test:load:video",
    "test:a11y": "playwright test --config=playwright.config.a11y.ts",
    "test:a11y:ui": "playwright test --config=playwright.config.a11y.ts --ui",
    "test:a11y:debug": "playwright test --config=playwright.config.a11y.ts --debug",
    "test:a11y:headed": "playwright test --config=playwright.config.a11y.ts --headed",
    "test:a11y:wcag": "playwright test tests/a11y/wcag.spec.ts --config=playwright.config.a11y.ts",
    "test:a11y:keyboard": "playwright test tests/a11y/keyboard-navigation.spec.ts --config=playwright.config.a11y.ts",
    "test:a11y:screen-reader": "playwright test tests/a11y/screen-reader.spec.ts --config=playwright.config.a11y.ts",
    "test:a11y:contrast": "playwright test tests/a11y/contrast.spec.ts --config=playwright.config.a11y.ts",
    "test:a11y:mobile": "playwright test tests/a11y/mobile-a11y.spec.ts --config=playwright.config.a11y.ts",
    "test:a11y:report": "playwright show-report --config=playwright.config.a11y.ts",
    "scan:secrets": "gitleaks detect --verbose --source . --config .gitleaks.toml",
    "scan:secrets:staged": "gitleaks detect --verbose --source . --staged --config .gitleaks.toml",
    "scan:install": "bash scripts/install-tools.sh",
    "scan:verify": "bash scripts/verify-secret-scan.sh",
    "precommit-install": "pre-commit install",
    "prepare": "husky install || true",
    "husky:install": "npx husky install",
    "husky:add": "npx husky add",
    "quality:full": "npm run lint && npm run typecheck && npm run test -- --coverage"
  },
