# DoctorMX Marketing Automation Infrastructure
# Copy this to .env and fill in your actual values

# n8n Configuration
N8N_PASSWORD=your_secure_n8n_password
N8N_HOST=automation.doctormx.com
N8N_WEBHOOK_URL=https://automation.doctormx.com
POSTGRES_PASSWORD=your_postgres_password
GRAFANA_PASSWORD=your_grafana_password

# DoctorMX Platform Integration
DOCTORMX_API_URL=https://doctormx.netlify.app
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# WhatsApp Business API (Critical for Mexican Market)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_APP_SECRET=your_whatsapp_app_secret
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Email Marketing (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=dr.simeon@doctormx.com
SENDGRID_FROM_NAME=Dr. Simeon - DoctorMX

# Social Media APIs
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=doctormx_bot
REDDIT_PASSWORD=your_reddit_password

# AI Services
OPENAI_API_KEY=your_openai_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key

# Analytics and Tracking
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ANALYTICS_MEASUREMENT_ID=your_ga4_measurement_id
FACEBOOK_PIXEL_ID=your_facebook_pixel_id
MIXPANEL_TOKEN=your_mixpanel_token

# Mexican Market Specific
MEXICO_TIMEZONE=America/Mexico_City
DEFAULT_LANGUAGE=es-MX
IMSS_API_KEY=your_imss_api_key
ISSSTE_API_KEY=your_issste_api_key

# Security and Compliance
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key
COFEPRIS_COMPLIANCE_KEY=your_cofepris_key

# Monitoring and Alerts
SLACK_WEBHOOK_URL=your_slack_webhook_url
ALERT_EMAIL=alerts@doctormx.com
SENTRY_DSN=your_sentry_dsn

# Performance and Scaling
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://n8n:${POSTGRES_PASSWORD}@postgres:5432/n8n
MAX_CONCURRENT_WORKFLOWS=100
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000 