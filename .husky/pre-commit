#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit quality gates..."

# 1. ESLint + Prettier on staged files
echo "  → Linting and formatting staged files..."
npx lint-staged || exit 1

# 2. TypeScript strict check
echo "  → Running TypeScript strict check..."
npm run type-check || exit 1

# 3. Test files that are staged
echo "  → Running tests on staged files..."
npm run test:changed || exit 1

echo "✅ Pre-commit quality gates passed!"
