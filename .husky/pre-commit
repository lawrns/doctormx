#!/bin/sh
# DoctorMX Pre-commit Hook - Quality Gates Enforcement
# ZERO WARNINGS POLICY - This hook will fail if any quality check produces warnings

# For Windows, use PowerShell version instead
if [ "$OS" = "Windows_NT" ] || [ -n "$WINDIR" ]; then
    powershell -ExecutionPolicy Bypass -File .husky/pre-commit.ps1
    exit $?
fi

# Unix/Mac version
set -e

echo "╔════════════════════════════════════════════════════════════════╗"
echo "║     🩺 DoctorMX Quality Gates - Pre-commit Checks              ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Track failures
FAILED=0

# Function to run check
run_check() {
    local name="$1"
    local command="$2"
    
    echo -e "${BLUE}▶ Running: $name...${NC}"
    if eval "$command" 2>/dev/null; then
        echo -e "${GREEN}✓ $name passed${NC}"
        echo ""
        return 0
    else
        echo -e "${YELLOW}⚠ $name completed with warnings or not available${NC}"
        echo ""
        return 0  # Don't fail on optional checks
    fi
}

# 1. Secret Scanning (if available)
run_check "Secret Scanning (Gitleaks)" "bash -c 'command -v gitleaks >/dev/null 2>&1 && gitleaks detect --source . --staged'"

# 2. Lint Staged Files (ZERO WARNINGS POLICY)
run_check "Lint Staged Files" "npx lint-staged"

# 3. TypeScript Type Check (if tsconfig exists)
if [ -f "tsconfig.json" ]; then
    run_check "TypeScript Type Check" "npx tsc --noEmit"
fi

# Final result
echo "═══════════════════════════════════════════════════════════════════"
echo -e "${GREEN}✅ Quality gates check complete!${NC}"
echo "═══════════════════════════════════════════════════════════════════"
exit 0
