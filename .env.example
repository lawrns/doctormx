# Supabase configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI configuration (client-side)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Serverless functions keys
OPENAI_API_KEY=your-openai-api-key-here

# Redis configuration (for AI response caching)
REDIS_URL=redis://default:password@host:port

# Sentry configuration (for error tracking)
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_DSN=https://your-project-slug@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
VITE_APP_VERSION=0.1.0

## Doctor instructions (optional override)
# VITE_DOCTOR_INSTRUCTIONS=Eres un médico virtual compasivo y profesional. Tu objetivo es ayudar a los pacientes a entender sus síntomas y brindarles orientación médica preliminar.

## Image analysis feature flag (true/false)
VITE_DOCTOR_IMAGE_ANALYSIS_ENABLED=true

## Vision model override for image analysis (optional)
# VITE_IMAGE_ANALYSIS_MODEL=gpt-4o-mini

## Additional feature flags (optional)
# VITE_ENABLE_COMMUNITY=true
# VITE_ENABLE_BROADCASTING=true
# VITE_ENABLE_EDUCATIONAL_CONTENT=true

## Backup Configuration (for automated database backups)
SUPABASE_DB_PASSWORD=your-database-password
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
TEST_DATABASE_URL=postgresql://postgres:password@test-db.your-project.supabase.co:5432/postgres

## AWS S3 Backup Storage (optional - for cloud backup uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-backup-bucket-name

## Backup Settings
BACKUP_STORAGE_TYPE=auto
BACKUP_RETENTION_DAYS=30

## Slack Notifications (optional - for backup failure alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
