# Supabase configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI configuration (client-side)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# OpenRouter — sole LLM provider (MiniMax M2.7 + Kimi K2.6)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Legacy provider keys (disabled — kept for extreme fallback only)
# GLM_API_KEY=your-glm-coding-plan-api-key-here
# KIMI_API_KEY=your-kimi-api-key-here
# KIMI_BASE_URL=https://api.kimi.com/coding/v1

# OpenAI — Whisper transcription only (not used for chat)
OPENAI_API_KEY=your-openai-api-key-here

# Redis configuration (for AI response caching)
REDIS_URL=redis://default:password@host:port

# Sentry configuration (for error tracking)
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_DSN=https://your-project-slug@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
VITE_APP_VERSION=0.1.0

## Doctor instructions (optional override)
# VITE_DOCTOR_INSTRUCTIONS=Eres un médico virtual compasivo y profesional. Tu objetivo es ayudar a los pacientes a entender sus síntomas y brindarles orientación médica preliminar.

## Image analysis feature flag (true/false)
VITE_DOCTOR_IMAGE_ANALYSIS_ENABLED=true

## Vision model override for image analysis (optional)
# VITE_IMAGE_ANALYSIS_MODEL=gpt-4o-mini

## Additional feature flags (optional)
# VITE_ENABLE_COMMUNITY=true
# VITE_ENABLE_BROADCASTING=true
# VITE_ENABLE_EDUCATIONAL_CONTENT=true

# Stripe configuration
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_CLINIC_PRICE_ID=price_...
