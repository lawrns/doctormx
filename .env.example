# =============================================================================
# Doctor.mx Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# For production, use .env.production
# For testing, use .env.test
#
# ⚠️  IMPORTANT: Never commit .env.local or .env.production to version control!
#     These files contain sensitive credentials.
# =============================================================================

# =============================================================================
# CORE APPLICATION SETTINGS (Required)
# =============================================================================

# Base URL of your application (used for redirects and webhooks)
# Example: https://doctory.mx (production) or http://localhost:3000 (development)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application version (displayed in health checks and Sentry)
NEXT_PUBLIC_APP_VERSION=0.1.0

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these values from your Supabase project dashboard:
# Project Settings > API > Project URL and anon/public key

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (client-side, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only, keep secret!)
# Used for admin operations. Never expose this to the client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database password (for migrations and backup scripts)
SUPABASE_DB_PASSWORD=your-database-password

# Direct database connection URL (for Prisma or direct connections)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Test database URL (for CI/CD)
TEST_DATABASE_URL=postgresql://postgres:password@test-db.your-project.supabase.co:5432/postgres

# =============================================================================
# AI SERVICE PROVIDERS (Required for AI features)
# =============================================================================

# OpenAI API Key (primary AI provider)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# OpenRouter API Key (alternative AI provider)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# DeepSeek API Key (alternative AI provider)
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key

# GLM (Zhipu AI) API Key (alternative AI provider)
# Get from: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key

# AI Model Configuration (optional overrides)
AI_PROVIDER=openai
AI_MODEL_NAME=gpt-4o
AI_MODEL_VERSION=2024-08-06
AI_TRAINING_CUTOFF=2024-04

# =============================================================================
# STRIPE PAYMENT PROCESSING (Required for payments)
# =============================================================================
# Get from: https://dashboard.stripe.com/test/apikeys

# Stripe Publishable Key (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Secret Key (server-side only, keep secret!)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe Webhook Secret (for webhook signature verification)
# Get from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Or from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs for subscription plans (optional)
# Create these in your Stripe Dashboard > Products
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_ELITE_PRICE_ID=price_elite
STRIPE_PRICE_PRO=price_pro_id_here
STRIPE_PRICE_ELITE=price_elite_id_here

# =============================================================================
# VIDEO CONSULTATION (Required for video calls)
# =============================================================================
# Get from: https://dashboard.daily.co/

# Daily.co API Key for video consultations
DAILY_API_KEY=your-daily-api-key

# Daily.co Domain (e.g., your-domain.daily.co)
DAILY_DOMAIN=your-domain.daily.co

# =============================================================================
# NOTIFICATION SERVICES (Optional but recommended)
# =============================================================================

# --- Resend (Email notifications) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# --- Twilio (SMS/WhatsApp notifications) ---
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC_your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- WhatsApp Business API ---
# Get from: Meta Developer Portal
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# =============================================================================
# REDIS / UPSTASH (Optional - for caching and rate limiting)
# =============================================================================
# Get from: https://console.upstash.com/

# Redis URL (for AI response caching)
REDIS_URL=redis://default:password@host:port

# Upstash Redis REST API (alternative)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# SENTRY ERROR TRACKING (Optional but recommended for production)
# =============================================================================
# Get from: https://sentry.io/settings/projects/

# Sentry DSN (client-side)
NEXT_PUBLIC_SENTRY_DSN=https://your-project-slug@sentry.io/project-id

# Sentry Auth Token (for source maps upload)
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token

# Sentry Organization and Project
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# =============================================================================
# MONITORING & WEBHOOKS (Optional)
# =============================================================================

# Cron Secret (for securing cron job endpoints)
CRON_SECRET=your-random-cron-secret

# Webhook Security
WEBHOOK_IP_ALLOWLIST_ENABLED=true
WEBHOOK_SKIP_VERIFICATION_IN_DEV=false

# =============================================================================
# PHARMACY WEBHOOK SECURITY (Required for pharmacy integration)
# =============================================================================

# Pharmacy Webhook Secret (for HMAC-SHA256 signature verification)
# Generate with: openssl rand -hex 32
PHARMACY_WEBHOOK_SECRET=your_pharmacy_webhook_secret_here

# Pharmacy IP Allowlist (comma-separated list of allowed IPs)
# Example: PHARMACY_IP_ALLOWLIST=192.168.1.100,10.0.0.50
PHARMACY_IP_ALLOWLIST=

# Monitoring Webhook Secret
MONITORING_WEBHOOK_SECRET=your_random_secret_here

# Slack Webhook (for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Status Page Configuration
STATUS_PAGE_API_KEY=your_statuspage_api_key
STATUS_PAGE_ID=your_page_id
STATUS_COMPONENT_API=component_id_for_api
STATUS_COMPONENT_WEBSITE=component_id_for_website
STATUS_COMPONENT_DATABASE=component_id_for_database
STATUS_COMPONENT_AI=component_id_for_ai_services
STATUS_COMPONENT_PAYMENTS=component_id_for_payments
STATUS_COMPONENT_NOTIFICATIONS=component_id_for_notifications

# PagerDuty Escalation
ESCALATION_WEBHOOK_URL=https://events.pagerduty.com/v2/enqueue
PAGERDUTY_ROUTING_KEY=your_routing_key

# Alert Email
ALERT_EMAIL=admin@doctory.mx

# UptimeRobot Configuration
UPTIMEROBOT_API_KEY=urXXXXXXXXXXXXXXXX
UPTIMEROBOT_EMAIL_ALERT_ID=12345
UPTIMEROBOT_SLACK_ALERT_ID=67890

# Pingdom Configuration
PINGDOM_API_TOKEN=your_pingdom_api_token
PINGDOM_EMAIL=admin@doctory.mx

# =============================================================================
# BACKUP CONFIGURATION (Optional)
# =============================================================================

# Backup Storage Type (auto, s3, local)
BACKUP_STORAGE_TYPE=auto

# Backup Retention (days)
BACKUP_RETENTION_DAYS=30

# AWS S3 Backup (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-backup-bucket-name

# =============================================================================
# ENCRYPTION & SECURITY (Optional)
# =============================================================================

# Master encryption key for sensitive data
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=your-256-bit-encryption-key-hex-encoded

# =============================================================================
# FEATURE FLAGS (Optional - enable/disable features)
# =============================================================================

# AI Features
NEXT_PUBLIC_AI_PRECONSULTA_ENABLED=true
NEXT_PUBLIC_AI_TRANSCRIPTION_ENABLED=true
NEXT_PUBLIC_AI_FOLLOWUP_ENABLED=true
NEXT_PUBLIC_DOCTOR_IMAGE_ANALYSIS_ENABLED=true

# Video Consultations
NEXT_PUBLIC_VIDEO_APPOINTMENTS_ENABLED=true

# Prescriptions
NEXT_PUBLIC_PRESCRIPTIONS_ENABLED=true

# Community Features (future)
NEXT_PUBLIC_ENABLE_COMMUNITY=false
NEXT_PUBLIC_ENABLE_BROADCASTING=false
NEXT_PUBLIC_ENABLE_EDUCATIONAL_CONTENT=false

# AI Pre-consulta public flag
NEXT_PUBLIC_AI_PRECONSULTA=true

# =============================================================================
# CUSTOM AI INSTRUCTIONS (Optional)
# =============================================================================

# Override default doctor AI personality
VITE_DOCTOR_INSTRUCTIONS=Eres un médico virtual compasivo y profesional. Tu objetivo es ayudar a los pacientes a entender sus síntomas y brindarles orientación médica preliminar.

# Image Analysis Model Override
VITE_IMAGE_ANALYSIS_MODEL=gpt-4o-mini

# =============================================================================
# LEGACY / VITE COMPATIBILITY (Optional)
# =============================================================================
# These are kept for backwards compatibility with older code

VITE_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
VITE_OPENAI_API_KEY=${OPENAI_API_KEY}
VITE_APP_VERSION=${NEXT_PUBLIC_APP_VERSION}
VITE_DOCTOR_IMAGE_ANALYSIS_ENABLED=${NEXT_PUBLIC_DOCTOR_IMAGE_ANALYSIS_ENABLED}
VITE_ENABLE_COMMUNITY=${NEXT_PUBLIC_ENABLE_COMMUNITY}
VITE_ENABLE_BROADCASTING=${NEXT_PUBLIC_ENABLE_BROADCASTING}
VITE_ENABLE_EDUCATIONAL_CONTENT=${NEXT_PUBLIC_ENABLE_EDUCATIONAL_CONTENT}

# =============================================================================
# DEVELOPMENT / DEBUGGING (Development only)
# =============================================================================

# Log Level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Vercel Environment (set automatically on Vercel)
VERCEL_ENV=development

# =============================================================================
# VALIDATION CHECKLIST
# =============================================================================
# Before deploying, ensure you have configured:
# 
# [ ] NEXT_PUBLIC_SUPABASE_URL
# [ ] NEXT_PUBLIC_SUPABASE_ANON_KEY
# [ ] SUPABASE_SERVICE_ROLE_KEY
# [ ] OPENAI_API_KEY (or alternative AI provider)
# [ ] NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (if using payments)
# [ ] STRIPE_SECRET_KEY
# [ ] STRIPE_WEBHOOK_SECRET
# [ ] DAILY_API_KEY (if using video)
# [ ] RESEND_API_KEY (if using email)
# [ ] PHARMACY_WEBHOOK_SECRET (if using pharmacy webhooks)
# [ ] NEXT_PUBLIC_APP_URL (set to production URL)
#
# For help, see: docs/TROUBLESHOOTING.md
# =============================================================================
