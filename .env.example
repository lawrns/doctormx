# Doctor.mx Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
PORT=8787
NODE_ENV=development

# ============================================
# OpenAI Configuration (for AI Triage)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# WhatsApp Cloud API Configuration
# Get these from Meta Business Manager
# Guide: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# ============================================

# Your WhatsApp Business Phone Number ID
# Found in: Meta Business Manager > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Your WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Permanent Access Token
# Generate from: Meta Business Manager > System Users > Generate Token
# Permissions needed: whatsapp_business_messaging, whatsapp_business_management
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token

# Webhook Verify Token (you choose this)
# Use a secure random string
WHATSAPP_VERIFY_TOKEN=doctor_mx_secure_token_2025_change_this

# Webhook Secret (optional but recommended for production)
# Found in: Meta Business Manager > WhatsApp > Configuration
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret

# ============================================
# Supabase Configuration (for User Database)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# Google Places API (for Specialist Search)
# ============================================
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ============================================
# Payment Configuration (Future)
# ============================================
# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Conekta (Mexico)
CONEKTA_PRIVATE_KEY=key_your-conekta-private-key

# ============================================
# CFDI / SAT Configuration (Future)
# For Mexican tax invoices
# ============================================
SAT_RFC=your-rfc
SAT_CERTIFICATE_PATH=path/to/certificate.cer
SAT_KEY_PATH=path/to/key.key

# ============================================
# Email Configuration (Future)
# For notifications and receipts
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@doctor.mx
SMTP_PASSWORD=your-smtp-password

# ============================================
# Pharmacy Partner Integration (Future)
# ============================================
PHARMACY_API_KEY=your-pharmacy-partner-api-key
PHARMACY_API_URL=https://api.pharmacy-partner.com

# ============================================
# Monitoring & Analytics (Future)
# ============================================
SENTRY_DSN=your-sentry-dsn
MIXPANEL_TOKEN=your-mixpanel-token
