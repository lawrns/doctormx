# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter — sole LLM provider (MiniMax M2.7 + Kimi K2.6)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI — Whisper transcription only (not used for chat)
OPENAI_API_KEY=your-openai-api-key-here

# Redis configuration (for AI response caching)
REDIS_URL=redis://default:password@host:port

# Google verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Social media URLs (for structured data)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# Sentry configuration (for error tracking)
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_DSN=https://your-project-slug@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Stripe configuration
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_ELITE_ANNUAL_PRICE_ID=price_...
STRIPE_CLINIC_PRICE_ID=price_...
STRIPE_CLINIC_ANNUAL_PRICE_ID=price_...
