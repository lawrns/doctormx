# Supabase configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI configuration (client-side)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Serverless functions keys
OPENAI_API_KEY=your-openai-api-key-here

## Doctor instructions (optional override)
# VITE_DOCTOR_INSTRUCTIONS=Eres un médico virtual compasivo y profesional. Tu objetivo es ayudar a los pacientes a entender sus síntomas y brindarles orientación médica preliminar.

## Image analysis feature flag (true/false)
VITE_DOCTOR_IMAGE_ANALYSIS_ENABLED=true

## Vision model override for image analysis (optional)
# VITE_IMAGE_ANALYSIS_MODEL=gpt-4o-mini

## Additional feature flags (optional)
# VITE_ENABLE_COMMUNITY=true
# VITE_ENABLE_BROADCASTING=true
# VITE_ENABLE_EDUCATIONAL_CONTENT=true
