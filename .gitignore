# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Scraper files with potential secrets
doctoralia_scraper/*.html
doctoralia_scraper/page-source.html
doctoralia_scraper/real-page-source.html
doctoralia_scraper/test-page-source.html

# Sentry - Don't commit auth tokens
.sentryclirc

# E2E test artifacts (regenerable)
/playwright-report/
/test-results/
dev.log

# Git worktrees (duplicates repo)
/worktrees/

# Home directory (security risk - never track ~/)
~/

# Large/archive files that shouldn't be tracked
*.zip

# AI agent memory/logs (may contain sensitive data)
.claude/MEMORY/

# Untracked project documentation drafts
*_DRAFT.md
*_BACKUP.md

# Secret scanning - Allowlist files (may contain sensitive patterns)
.gitleaks.allow
.gitleaks-report.*

# Security scanning reports
security-reports/
sarif-reports/

# Pre-commit cache
.pre-commit-cache/

# Temporary secret storage (for testing)
.secrets-test/

# =============================================================================
# Build & Test Artifacts (Root Level)
# =============================================================================

# Log files
*.log
test-output.log
build-error.log
dev.log

# Build outputs (beyond standard Next.js)
build/
dist/
.turbo/

# Dependency analysis
dependency_tree.json
dependency-tree.json

# Backup files
*.backup
*.bak
package.json.backup
package-lock.json.backup

# =============================================================================
# Configuration Files (Optional - Can be committed if desired)
# =============================================================================

# Docker (can be committed, but often environment-specific)
# .dockerignore
# Dockerfile

# Linting/Formatting config (usually should be committed)
# .lintstagedrc.json
# .prettierrc.json
# .eslintrc.json
# commitlint.config.js

# =============================================================================
# Temporary & Cache Directories
# =============================================================================

# Temp directories
temp*/
tmp*/
temp_*/
tmp_*/
temp_kimi_extract/

# Cache directories
.cache/
.parcel-cache/
.vite/

