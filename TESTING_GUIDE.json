  "browserAITestingInstructions": {
    "overview": "Use a browser-connected AI (like Claude with browser access) to navigate and test the Doctor.mx application",
    "steps": [
      {
        "task": "Initial Setup",
        "instructions": [
          "Open http://localhost:5176 in browser",
          "Verify homepage loads with medical theme and branding",
          "Check that navigation menu is visible",
          "Confirm 'Consultar ahora' CTA button is prominent"
        ]
      },
      {
        "task": "Test User Registration Flow",
        "instructions": [
          "Click 'Registrarse' button",
          "Fill form with test data: name='Test User', email='test@test.com', password='Test123!', role='patient'",
          "Submit and verify redirect to dashboard or doctor AI page",
          "Check that user appears in Supabase 'users' table"
        ]
      },
      {
        "task": "Test AI Doctor Chat",
        "instructions": [
          "Navigate to /doctor page",
          "Type symptom in Spanish: 'Tengo fiebre de 38 grados y dolor de garganta desde hace 3 días'",
          "Observe AI response appears within 5-10 seconds",
          "Verify response includes medical guidance, questions, and disclaimer",
          "Check if specialty suggestion triggers specialist list",
          "Interact with specialist cards (call button, website button)"
        ]
      },
      {
        "task": "Test Doctor Directory",
        "instructions": [
          "Navigate to /doctors",
          "Use search bar to search for 'Cardio'",
          "Select 'Cardiología' from specialty dropdown",
          "Toggle 'Solo disponibles ahora' checkbox",
          "Click on a doctor card and verify profile loads",
          "Test back navigation to directory"
        ]
      },
      {
        "task": "Test Patient Dashboard",
        "instructions": [
          "Navigate to /dashboard",
          "Switch between all 3 tabs: Consultas, Recetas, Referencias",
          "Verify each tab shows appropriate empty state or data",
          "Check stats cards show numerical counts",
          "Test navigation from dashboard to consultation details (if data exists)"
        ]
      },
      {
        "task": "Test Responsive Design",
        "instructions": [
          "Resize browser to mobile width (375px)",
          "Verify mobile menu appears and works",
          "Check that chat interface is usable on mobile",
          "Test specialist cards stack vertically on mobile",
          "Verify all text is readable and buttons are tappable"
        ]
      },
      {
        "task": "Test Error Handling",
        "instructions": [
          "Try accessing /doctor without logging in (should redirect to login)",
          "Try invalid login credentials (should show error)",
          "Try submitting empty chat message (should be prevented)",
          "Try searching for non-existent specialty (should show 'no results')"
        ]
      }
    ],
    "expectedBehavior": {
      "performance": "Page loads < 2s, AI responses < 10s",
      "accessibility": "Keyboard navigable, ARIA labels present",
      "security": "Protected routes require authentication",
      "ux": "Smooth animations, clear feedback, intuitive navigation"
    }
  },

