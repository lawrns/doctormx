      "workflow": "AI Doctor Chat Test",
      "priority": "HIGH",
      "url": "http://localhost:5176/doctor",
      "prerequisites": ["User must be logged in"],
      "steps": [
        {
          "step": 1,
          "action": "Navigate to http://localhost:5176/doctor",
          "expected": "AI Doctor chat interface loads with welcome message"
        },
        {
          "step": 2,
          "action": "Type a medical symptom (e.g., 'Tengo dolor de cabeza desde hace 2 días')",
          "expected": "AI responds with medical guidance in Spanish"
        },
        {
          "step": 3,
          "action": "Continue conversation with follow-up details",
          "expected": "AI asks relevant medical questions and provides triage"
        },
        {
          "step": 4,
          "action": "Wait for specialty suggestion in response",
          "expected": "AI suggests a medical specialty (e.g., 'Especialidad Sugerida: Neurólogo')"
        },
        {
          "step": 5,
          "action": "Verify specialist list appears automatically",
          "expected": "List of nearby specialists appears with contact info, ratings, and call-to-action buttons"
        }
      ],
      "validation": {
        "aiResponse": "Must be in Spanish, medically accurate, and include disclaimer",
        "specialistSearch": "Automatically triggered when specialty is detected",
        "uiElements": "Chat messages, loading states, and specialist cards render correctly"
      }
